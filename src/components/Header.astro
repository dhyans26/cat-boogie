---
import { REPOSITORY_URL } from "../consts";
import HeaderLink from "./HeaderLink.astro";
import Project from "../assets/project.svg";
import ThemeToggle from "./ThemeToggle.astro";
---

<header>
  <div class="header-inner">
    <div class="header-left">
      <a href="https://hackclub.com" target="_blank" rel="noopener noreferrer" class="orpheus-link" aria-label="Hack Club">
        <img src="https://assets.hackclub.com/flag-orpheus-top.svg" alt="" width="120" height="40" />
      </a>
      <h2 class="project-logo">
        <a href="/">
          <Project style="height: 28px; width: auto;" />
        </a>
      </h2>
    </div>

    <nav class="desktop-nav">
      <HeaderLink href="/">Home</HeaderLink>
      <HeaderLink href="/overview">Overview</HeaderLink>
    </nav>

    <div class="header-right">
      <ThemeToggle />
      <a href={REPOSITORY_URL} target="_blank" rel="noopener noreferrer" class="icon-link" aria-label="Project YSWS on GitHub">
        <svg viewBox="0 0 16 16" aria-hidden="true" width="22" height="22">
          <path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
        </svg>
      </a>
      <button class="mobile-menu-toggle" aria-label="Toggle navigation" aria-expanded="false">
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
      </button>
    </div>
  </div>

  <div class="mobile-menu" aria-hidden="true">
    <HeaderLink href="/">Home</HeaderLink>
    <HeaderLink href="/overview">Overview</HeaderLink>
    <a href={REPOSITORY_URL} target="_blank" rel="noopener noreferrer">GitHub</a>
  </div>
</header>

<script>
  const toggle = document.querySelector('.mobile-menu-toggle');
  const menu = document.querySelector('.mobile-menu');

  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      const expanded = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!expanded));
      menu.setAttribute('aria-hidden', String(expanded));
      menu.classList.toggle('open');
      toggle.classList.toggle('active');
    });
  }
</script>

<style>
  header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255, 255, 255, 0.75);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(236, 55, 80, 0.15);
    transition: background 0.3s, border-color 0.3s;
  }

  :global([data-theme="dark"]) header {
    background: rgba(26, 26, 46, 0.8);
    border-bottom-color: rgba(255, 255, 255, 0.06);
  }

  .header-inner {
    max-width: var(--container-width);
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: var(--header-height);
  }

  .header-left {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .orpheus-link {
    display: flex;
    align-items: center;
    padding: 0;
    border: none;
    transition: opacity 0.2s;
  }

  .orpheus-link:hover {
    opacity: 0.8;
  }

  .orpheus-link img {
    display: block;
    border-radius: 0;
  }

  .project-logo {
    margin: 0;
    font-size: 1em;
    line-height: 1;
  }

  .project-logo a {
    display: flex;
    align-items: center;
    padding: 0;
    border: none;
    transition: opacity 0.2s;
  }

  .project-logo a:hover {
    opacity: 0.7;
  }

  .desktop-nav {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .desktop-nav :global(a) {
    padding: 0.5rem 1rem;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text);
    border-radius: 8px;
    transition: background 0.2s, color 0.2s;
    border: none;
  }

  .desktop-nav :global(a:hover) {
    background: rgba(236, 55, 80, 0.08);
    color: var(--accent);
    text-decoration: none;
  }

  .desktop-nav :global(a.active) {
    background: rgba(236, 55, 80, 0.1);
    color: var(--accent);
    text-decoration: none;
    font-weight: 700;
  }

  :global([data-theme="dark"]) .desktop-nav :global(a:hover) {
    background: rgba(236, 55, 80, 0.15);
  }

  :global([data-theme="dark"]) .desktop-nav :global(a.active) {
    background: rgba(236, 55, 80, 0.2);
  }

  .header-right {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .icon-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: 8px;
    color: var(--text);
    transition: background 0.2s, color 0.2s;
    padding: 0;
    border: none;
  }

  .icon-link:hover {
    background: rgba(236, 55, 80, 0.08);
    color: var(--accent);
    text-decoration: none;
  }

  :global([data-theme="dark"]) .icon-link:hover {
    background: rgba(236, 55, 80, 0.15);
  }

  .mobile-menu-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 38px;
    height: 38px;
    background: none;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    padding: 8px;
    transition: background 0.2s;
  }

  .mobile-menu-toggle:hover {
    background: rgba(236, 55, 80, 0.08);
  }

  .hamburger-line {
    display: block;
    width: 100%;
    height: 2px;
    background: var(--text);
    border-radius: 2px;
    transition: transform 0.3s ease, opacity 0.3s ease;
  }

  .mobile-menu-toggle.active .hamburger-line:nth-child(1) {
    transform: rotate(45deg) translate(5px, 5px);
  }

  .mobile-menu-toggle.active .hamburger-line:nth-child(2) {
    opacity: 0;
  }

  .mobile-menu-toggle.active .hamburger-line:nth-child(3) {
    transform: rotate(-45deg) translate(5px, -5px);
  }

  .mobile-menu {
    display: none;
    flex-direction: column;
    max-width: var(--container-width);
    margin: 0 auto;
    padding: 0.5rem 1.5rem 1rem;
    border-top: 1px solid rgba(236, 55, 80, 0.1);
  }

  :global([data-theme="dark"]) .mobile-menu {
    border-top-color: rgba(255, 255, 255, 0.06);
  }

  .mobile-menu a {
    padding: 0.75rem 0.5rem;
    color: var(--text);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
    border-radius: 0;
    transition: color 0.2s;
  }

  :global([data-theme="dark"]) .mobile-menu a {
    border-bottom-color: rgba(255, 255, 255, 0.06);
  }

  .mobile-menu a:last-child {
    border-bottom: none;
  }

  .mobile-menu a:hover {
    color: var(--accent);
    text-decoration: none;
  }

  .mobile-menu.open {
    display: flex;
  }

  @media (max-width: 720px) {
    .header-inner {
      padding: 0 1rem;
    }

    .orpheus-link img {
      width: 80px;
      height: auto;
    }

    .project-logo {
      display: none;
    }

    .desktop-nav {
      display: none;
    }

    .icon-link {
      display: none;
    }

    .mobile-menu-toggle {
      display: flex;
    }
  }
</style>
