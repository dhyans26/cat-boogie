---
const today = new Date();
import { REPOSITORY_URL } from '../consts';

// Fetch latest commit info from GitHub API at build time
let commitHash = '';
let commitMessage = '';
let commitDate = '';
let commitUrl = '';

try {
	const repoPath = REPOSITORY_URL.replace('https://github.com/', '');
	const res = await fetch(`https://api.github.com/repos/${repoPath}/commits?per_page=1`);
	if (res.ok) {
		const [latest] = await res.json();
		commitHash = latest.sha.slice(0, 7);
		commitMessage = latest.commit.message.split('\n')[0]; // first line only
		commitDate = new Date(latest.commit.committer.date).toLocaleDateString('en-US', {
			year: 'numeric',
			month: 'short',
			day: 'numeric',
		});
		commitUrl = latest.html_url;
	}
} catch (e) {
	// silently fail — commit tracker just won't render
}
---

<footer>
	<div class="footer-inner">
		<div class="footer-top">
			<p class="made-by">Created with <span aria-label="love">♥</span> by <a href="https://github.com/bluelightning26" target="_blank">Dhyan</a> and <a href="https://github.com/ScapularSteam" target="_blank">David</a> @ <a href="https://hackclub.com">Hack Club</a></p>
			<div class="footer-links">
				<a href="/overview/credits">Credits</a>
				<span class="dot-sep" aria-hidden="true">·</span>
				<a href={REPOSITORY_URL} target="_blank">GitHub</a>
			</div>
		</div>

		{commitHash && (
			<div class="commit-tracker">
				<svg viewBox="0 0 16 16" width="14" height="14" aria-hidden="true">
					<path fill="currentColor" d="M11.93 8.5a4.002 4.002 0 0 1-7.86 0H.75a.75.75 0 0 1 0-1.5h3.32a4.002 4.002 0 0 1 7.86 0h3.32a.75.75 0 0 1 0 1.5Zm-1.43-.25a2.5 2.5 0 1 0-5 0 2.5 2.5 0 0 0 5 0Z"/>
				</svg>
				<a href={commitUrl} target="_blank" title={commitMessage}>
					<code>{commitHash}</code>
				</a>
				<span class="commit-msg">{commitMessage}</span>
				<span class="commit-date">{commitDate}</span>
			</div>
		)}

		<p class="copyright">&copy; {today.getFullYear()} Hack Club. 501(c)(3) nonprofit (EIN: 81-2908499)</p>
	</div>
</footer>
<style>
	footer {
		padding: 3rem 1.5rem 4rem;
		background: var(--surface);
		border-top: 1px solid var(--border);
		text-align: center;
		transition: background var(--transition-slow), border-color var(--transition-slow);
	}

	.footer-inner {
		max-width: var(--container-width);
		margin: 0 auto;
	}

	.footer-top {
		margin-bottom: 1.25rem;
	}

	.made-by {
		margin: 0 auto 0.75rem;
		font-size: 0.95rem;
		color: var(--text-muted);
		max-width: none;
	}

	.made-by a {
		color: var(--text);
		font-weight: 600;
		transition: color var(--transition-fast);
	}

	.made-by a:hover {
		color: var(--accent);
		text-decoration: none;
	}

	.footer-links {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
		font-size: 0.9rem;
	}

	.footer-links a {
		color: var(--text-muted);
		transition: color var(--transition-fast);
	}

	.footer-links a:hover {
		color: var(--accent);
		text-decoration: none;
	}

	.dot-sep {
		color: var(--text-muted);
		opacity: 0.5;
	}

	.commit-tracker {
		display: inline-flex;
		align-items: center;
		gap: 0.5em;
		flex-wrap: wrap;
		justify-content: center;
		margin: 1rem 0;
		padding: 0.5rem 1rem;
		font-size: 0.8rem;
		color: var(--text-muted);
		background: rgba(0, 0, 0, 0.03);
		border-radius: 999px;
		border: 1px solid var(--border);
	}

	:global([data-theme="dark"]) .commit-tracker {
		background: rgba(255, 255, 255, 0.03);
	}

	.commit-tracker code {
		background: rgba(0, 0, 0, 0.06);
		padding: 0.1em 0.4em;
		border-radius: 4px;
		font-size: 0.9em;
		font-family: ui-monospace, 'Cascadia Code', monospace;
		border: none;
		color: var(--text);
	}

	.commit-tracker a {
		color: var(--text);
		text-decoration: none;
	}

	.commit-tracker a:hover {
		text-decoration: underline;
		color: var(--accent);
	}

	.commit-msg {
		max-width: 200px;
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}

	.commit-date {
		opacity: 0.6;
	}

	.commit-date::before {
		content: '·';
		margin-right: 0.3em;
	}

	.copyright {
		font-size: 0.8rem;
		color: var(--text-muted);
		opacity: 0.7;
		margin: 0;
		max-width: none;
	}
</style>
