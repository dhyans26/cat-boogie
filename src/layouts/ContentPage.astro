---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import BackToTop from '../components/BackToTop.astro';

type Props = CollectionEntry<'overview'>['data'];

const { title, description, heroImage } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
	</head>

	<body class="pattern-dots">
		<a href="#main-content" class="skip-to-content">Skip to content</a>
		<Header />
		<main class="page-container" id="main-content" style="padding-top: 2rem;">
			<article class="post-article">
				<div class="hero-header">
					{heroImage && 
						<div class="hero-image-wrapper">
							<Image width={1020} height={510} src={heroImage} alt={title} />
						</div>
					}
					<div class="title-container text-center">
						<h1 class="mb-4">{title}</h1>
						<hr />
					</div>
				</div>
				<div class="prose">
					<slot />
				</div>
			</article>
		</main>
		<BackToTop />
		<Footer />
	</body>
</html>

<style>
	.post-article {
		background: rgba(255, 255, 255, 0.5);
		backdrop-filter: blur(16px);
		-webkit-backdrop-filter: blur(16px);
		border: 1px solid var(--border);
		border-radius: var(--radius-lg);
		box-shadow: var(--shadow-sm);
		overflow: hidden;
		margin-bottom: 4rem;
	}

	:global([data-theme="dark"]) .post-article {
		background: rgba(26, 26, 46, 0.6);
	}

	.hero-image-wrapper {
		width: 100%;
		border-bottom: 1px solid var(--border);
	}

	.hero-image-wrapper img {
		width: 100%;
		height: auto;
		display: block;
		border-radius: 0;
	}

	.title-container {
		padding: 2.5rem 2.5rem 0;
	}

	.title-container h1 {
		letter-spacing: -0.02em;
	}

	.prose {
		padding: 0 2.5rem 2.5rem;
		max-width: 780px;
		margin: 0 auto;
	}

	@media (max-width: 720px) {
		.title-container, .prose {
			padding-left: 1.25rem;
			padding-right: 1.25rem;
		}
	}
</style>
