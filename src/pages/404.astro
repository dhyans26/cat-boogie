---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';
---

<html lang="en">
	<head>
		<BaseHead title={`Page Not Found - ${SITE_TITLE}`} description="The page you're looking for doesn't exist." />
	</head>
	<body class="pattern-dots">
		<Header />
		<main class="page-container" id="main-content">
			<div class="not-found">
				<h1>404</h1>
				<p class="subtitle">Looks like this page shipped without us.</p>
				<p>The page you're looking for doesn't exist or has been moved.</p>
				<div class="actions">
					<a href="/" class="button">Back to Home</a>
					<a href="/overview" class="button outline">Browse Overview</a>
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	.not-found {
		text-align: center;
		padding: 6rem 1rem;
		max-width: 600px;
		margin: 0 auto;
	}

	.not-found h1 {
		font-size: clamp(5rem, 15vw, 10rem);
		line-height: 1;
		margin: 0;
		background: linear-gradient(135deg, var(--red), var(--purple));
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		letter-spacing: -0.04em;
	}

	.subtitle {
		font-size: 1.5rem;
		font-weight: 600;
		margin-bottom: 1rem;
	}

	.actions {
		display: flex;
		gap: 1rem;
		justify-content: center;
		margin-top: 2rem;
		flex-wrap: wrap;
	}
</style>
