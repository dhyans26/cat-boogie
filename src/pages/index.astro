---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import BackToTop from '../components/BackToTop.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

import HomeContent from '../content/home.md';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body class="pattern-dots">
		<a href="#main-content" class="skip-to-content">Skip to content</a>
		<Header />
		<main class="page-container" id="main-content">
			<section class="hero-section">
				<h1 class="hero-title">Build Your Own Workshop!</h1>
				<p class="hero-subtitle">Get your members and other clubs around the world shipping more projects!</p>
				
				<div class="hero-image-container">
					<img src="/workshop-image.png" alt="Image of a workshop" loading="lazy" />
				</div>
			</section>

			<section class="content-section">
				<div class="card intro-card">
					<h2 class="text-center mb-4">Ever wanted to...</h2>
					<p class="text-center lead">Create your own YSWS? Get more flexibility? Help others get creative?</p>
					<p class="text-center">This is your chance!</p>
					<img src="/hackers-assemble.png" alt="Dino Orpheus" class="centered-image" style="max-width: 200px;" loading="lazy" />
					<div class="prose">
						<HomeContent />
					</div>
				</div>
			</section>
		</main>
		<BackToTop />
		<Footer />
	</body>
</html>

<style>
	.hero-section {
		text-align: center;
		padding: 5rem 0 3rem;
	}

	.hero-title {
		font-size: clamp(2.5rem, 6vw, 4.5rem);
		line-height: 1.05;
		margin-bottom: 1.25rem;
		background: linear-gradient(135deg, var(--red), var(--purple));
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		display: inline-block;
		letter-spacing: -0.03em;
	}

	.hero-subtitle {
		font-size: 1.15rem;
		color: var(--text-muted);
		max-width: 550px;
		margin: 0 auto 3rem;
		line-height: 1.6;
	}

	.hero-image-container {
		max-width: 820px;
		margin: 0 auto;
		transform: rotate(-0.5deg);
		transition: transform var(--transition-slow);
		position: relative;
	}

	.hero-image-container::before {
		content: '';
		position: absolute;
		top: 15%;
		left: 50%;
		transform: translateX(-50%);
		width: 70%;
		height: 70%;
		background: linear-gradient(135deg, var(--red), var(--orange), var(--yellow));
		filter: blur(80px);
		z-index: -1;
		opacity: 0.35;
		border-radius: 50%;
	}

	.hero-image-container:hover {
		transform: rotate(0deg) scale(1.01);
	}

	.hero-image-container img {
		box-shadow: var(--shadow-hover);
		border: 3px solid rgba(255, 255, 255, 0.4);
		border-radius: var(--radius-lg);
	}

	:global([data-theme="dark"]) .hero-image-container img {
		border-color: rgba(255, 255, 255, 0.08);
	}

	:global([data-theme="dark"]) .hero-image-container::before {
		opacity: 0.15;
	}

	.content-section {
		max-width: 780px;
		margin: 3rem auto 5rem;
	}

	.intro-card {
		padding: 2.5rem;
		background: rgba(255, 255, 255, 0.5);
		backdrop-filter: blur(16px);
		-webkit-backdrop-filter: blur(16px);
		border: 1px solid var(--border);
		border-radius: var(--radius-lg);
	}

	:global([data-theme="dark"]) .intro-card {
		background: rgba(26, 26, 46, 0.6);
	}

	.lead {
		font-size: 1.1rem;
		font-weight: 500;
		color: var(--text);
		margin-bottom: 1.5rem;
	}

	.prose {
		line-height: 1.8;
	}

	.centered-image {
		display: block;
		margin: 1rem auto;
	}

	@media (max-width: 768px) {
		.hero-section {
			padding: 3rem 0 2rem;
		}

		.intro-card {
			padding: 1.5rem;
		}
	}
</style>